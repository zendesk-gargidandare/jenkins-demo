pipeline {
    agent any

    stages {
        stage('build') {
            steps {
                echo 'Building...'
                sleep 10
            }
        }
        stage('test') {
            steps {
                echo 'Testing...'
                sleep 30
            }
        }
        stage('deploy') {
            steps {
                echo 'Deploying...'
                sleep 30
            }
        }
    }
}
